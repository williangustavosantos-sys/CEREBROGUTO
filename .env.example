PORT=3001
GUTO_TIME_ZONE=Europe/Rome
GUTO_GEMINI_MODEL=gemini-3.1-flash-lite
# Voz via Gemini TTS (mesma API/chave do cérebro — generativelanguage).
# Se o primário falhar (ex.: 429/quota no plano grátis), cai no fallback automaticamente.
GUTO_VOICE_MODEL=gemini-2.5-flash-preview-tts
GUTO_VOICE_MODEL_FALLBACK=gemini-3.1-flash-tts-preview
GUTO_MODEL_TIMEOUT_MS=30000
GUTO_MODEL_TEMPERATURE=0.28
GUTO_ALLOWED_ORIGINS=http://localhost:3000
GUTO_RATE_LIMIT_WINDOW_MS=60000
GUTO_RATE_LIMIT_MAX_REQUESTS=120
GUTO_MEMORY_FILE=data/guto-memory.json
GUTO_DEFAULT_USER_ID=local-user
GEMINI_API_KEY=
OPENAI_API_KEY=
# VOICE_API_KEY agora é uma chave Gemini (AI Studio) — pode ser a MESMA do GEMINI_API_KEY.
VOICE_API_KEY=
WORKOUTX_API_KEY=
# Juiz LLM dos evals (release:gate). Com a chave, o gate mede nuance do chat;
# sem ela, cai no match por palavra-chave (--no-judge).
ANTHROPIC_API_KEY=
# Curador de treino — retry/backoff sob carga (defaults sãos; ajuste se precisar).
GUTO_CURATOR_MAX_ATTEMPTS=3
GUTO_CURATOR_BACKOFF_MS=500
# Storage PERSISTENTE das selfies de validação (Cloudinary).
# Sem estas credenciais o backend grava em tmp/ — EFÊMERO no Render (some no redeploy).
# Em produção (Render) defina as 3 vars abaixo OU a CLOUDINARY_URL única.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Alternativa: cloudinary://<api_key>:<api_secret>@<cloud_name> (tem MENOR precedência que as 3 acima)
CLOUDINARY_URL=
# Pasta/prefixo dos ativos no Cloudinary (opcional; default guto/validation)
CLOUDINARY_FOLDER=guto/validation
